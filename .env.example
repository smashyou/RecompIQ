# Template — copy to apps/web/.env.local and fill in real values.
# DO NOT put real secrets in this file. It's tracked in git.

# ----- Supabase -----
# Project ref lives in apps/web/.env.local; this template intentionally omits it.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
# Publishable key (browser-safe; replaces the legacy `anon` key). sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key (server-only — treat like a password). sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=
# Optional: skip interactive login by setting an access token from
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# ----- Vercel AI Gateway (Phase 9) -----
# Generate at https://vercel.com/d/ai-gateway
AI_GATEWAY_API_KEY=

# ----- Nutrition APIs -----
# https://fdc.nal.usda.gov/api-key-signup.html (free; DEMO_KEY works at low rate)
USDA_FDC_API_KEY=
# Open Food Facts requires no key. Be a good citizen with a real User-Agent.
OPEN_FOOD_FACTS_USER_AGENT="RecompIQ/0.1 (https://recompiq.vercel.app)"
# Optional fallback. https://www.nutritionix.com/business/api
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=

# ----- Vercel Blob (Phase 11 — photo food logging) -----
BLOB_READ_WRITE_TOKEN=

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_DEMO=true
